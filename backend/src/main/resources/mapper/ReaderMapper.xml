<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.library.mapper.ReaderMapper">

    <resultMap id="BaseResultMap" type="com.library.entity.Reader">
        <id column="reader_id" property="readerId"/>
        <result column="reader_no" property="readerNo"/>
        <result column="reader_name" property="readerName"/>
        <result column="reader_type" property="readerType"/>
        <result column="gender" property="gender"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="max_borrow_num" property="maxBorrowNum"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        reader_id, reader_no, reader_name, reader_type, gender, phone, email, max_borrow_num, status, create_time, update_time, is_deleted
    </sql>

    <select id="selectReaderPage" resultMap="BaseResultMap">
        SELECT *
        FROM reader
        WHERE is_deleted = 0
        <if test="query != null">
            <if test="query.readerNo != null and query.readerNo != ''">
                AND reader_no LIKE CONCAT('%', #{query.readerNo}, '%')
            </if>
            <if test="query.readerName != null and query.readerName != ''">
                AND reader_name LIKE CONCAT('%', #{query.readerName}, '%')
            </if>
            <if test="query.readerType != null">
                AND reader_type = #{query.readerType}
            </if>
            <if test="query.gender != null">
                AND gender = #{query.gender}
            </if>
            <if test="query.status != null">
                AND status = #{query.status}
            </if>
            <if test="query.phone != null and query.phone != ''">
                AND phone LIKE CONCAT('%', #{query.phone}, '%')
            </if>
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
